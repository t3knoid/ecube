# Jinja2 template → rendered to /opt/ecube/.env on the target VM.
# All values come from group_vars/ecube_hosts.yml (or vault overrides).

DATABASE_URL=postgresql://{{ postgres_user }}:{{ postgres_password }}@localhost/{{ postgres_db }}

SECRET_KEY={{ ecube_secret_key }}
ALGORITHM={{ ecube_algorithm }}
TOKEN_EXPIRE_MINUTES={{ ecube_token_expire_minutes }}

ROLE_RESOLVER={{ ecube_role_resolver }}
LOCAL_GROUP_ROLE_MAP={{ ecube_local_group_role_map }}

USB_DISCOVERY_INTERVAL={{ ecube_usb_discovery_interval }}
