#!/usr/bin/env bash
# Git pre-commit hook: verify generated artifacts stay in sync before commits land.
#
# Install:
#   cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Or configure the hooks directory once (applies to all hooks in .githooks/):
#   git config core.hooksPath .githooks

set -euo pipefail

MD_FILE="docs/testing/03-qa-testing-guide.md"
XLSX_FILE="docs/testing/ecube-qa-test-cases.xlsx"
HELP_MD_FILE="docs/operations/13-user-manual.md"
HELP_HTML_FILE="frontend/public/help/manual.html"
HELP_BUILD_SCRIPT="scripts/build-help.mjs"
HELP_PACKAGE_FILE="frontend/package.json"
DBML_FILE="docs/database/ecube-schema.dbml"
SCHEMA_MODEL_GLOB='^app/models/'

# Only run when either file is staged
if git diff --cached --name-only | grep -qE "(${MD_FILE}|${XLSX_FILE})"; then
    echo "pre-commit: checking QA test-case sync..."
    if ! python3 scripts/sync_qa_test_cases.py --check; then
        echo ""
        echo "ERROR: QA test-case Excel is out of sync with the markdown guide."
        echo "Run:  python3 scripts/sync_qa_test_cases.py --sync"
        echo "then stage the updated .xlsx and commit again."
        exit 1
    fi
fi

# Only run when the help source, generated help, or build/check wiring is staged
if git diff --cached --name-only | grep -qE "(${HELP_MD_FILE}|${HELP_HTML_FILE}|${HELP_BUILD_SCRIPT}|${HELP_PACKAGE_FILE})"; then
    echo "pre-commit: checking generated help sync..."
    if ! (cd frontend && npm run build:help:check); then
        echo ""
        echo "ERROR: Generated help is out of sync."
        echo "Run:  (cd frontend && npm run build:help)"
        echo "then stage frontend/public/help/manual.html and commit again."
        exit 1
    fi
fi

# Only run when SQLAlchemy model metadata or the generated DBML are staged
if git diff --cached --name-only | grep -qE "(${DBML_FILE})|${SCHEMA_MODEL_GLOB}"; then
    echo "pre-commit: checking DBML schema sync..."
    if ! python3 scripts/generate_dbml_schema.py --check; then
        echo ""
        echo "ERROR: DBML schema reference is out of sync with the latest schema changes."
        echo "Run:  python3 scripts/generate_dbml_schema.py"
        echo "then stage docs/database/ecube-schema.dbml and commit again."
        exit 1
    fi
fi
