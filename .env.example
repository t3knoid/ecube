# =============================================================================
# ECUBE Configuration — .env.example
# =============================================================================
# Ready-to-use defaults for a quick local or test deployment.
# Copy this file to .env:
#
#   cp .env.example .env
#
# Both Docker Compose and native deployments start in setup wizard mode.
# Open https://<host>:8443/setup after the service starts to provision
# the database and create the initial admin user.
#
# Docker Compose:  docker compose up
#   The .env file is bind-mounted into the container.  The setup wizard
#   writes DATABASE_URL here after provisioning; the value survives
#   container restarts.
#
# Native Install:  sudo ./install.sh
#   install.sh writes PG_SUPERUSER_NAME/PASS and may update additional
#   values (SERVE_FRONTEND_PATH, TRUST_PROXY_HEADERS) automatically.
#   Both native and Docker use the same credential defaulting cascade.
#
# Before going to production, replace SECRET_KEY and POSTGRES_PASSWORD
# with strong, unique values.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Left empty on fresh installs.  The setup wizard writes this value after
# database provisioning.  Do NOT set manually unless restoring a backup.
DATABASE_URL=

# ---------------------------------------------------------------------------
# PostgreSQL superuser credentials (setup wizard)
# ---------------------------------------------------------------------------
# These credentials are used by the setup wizard to create the application
# database, user, and schema.  They are cleared from this file automatically
# after successful provisioning.
#
# Docker:   Defaults to POSTGRES_USER / POSTGRES_PASSWORD (the same account
#           that initialises the postgres container).
# Native:   install.sh creates a dedicated superuser and writes the
#           credentials here automatically.
#
# The account must have CREATEDB privilege (or SUPERUSER).
PG_SUPERUSER_NAME=
PG_SUPERUSER_PASS=

# PostgreSQL container credentials.  Used by Docker Compose to initialise
# the postgres container.  PG_SUPERUSER_NAME/PASS default to these values
# when not explicitly set.
# Change POSTGRES_PASSWORD before any shared or production deployment.
POSTGRES_PASSWORD=ecube
POSTGRES_USER=ecube
POSTGRES_DB=ecube

# ---------------------------------------------------------------------------
# Security & Authentication
# ---------------------------------------------------------------------------
# JWT signing key — this test value works out of the box.
# Generate a production key with: openssl rand -hex 32
SECRET_KEY=ecube-test-secret-key-replace-before-going-to-production-00000000

# JWT signing algorithm
ALGORITHM=HS256

# JWT token lifetime in minutes
TOKEN_EXPIRE_MINUTES=60

# Role resolver provider: "local" (default), "ldap", or "oidc"
ROLE_RESOLVER=local

# ---------------------------------------------------------------------------
# Local group-to-role mapping (used when ROLE_RESOLVER=local)
# ---------------------------------------------------------------------------
# JSON object mapping local group names to lists of ECUBE role strings.
# Example: '{"evidence-admins": ["admin"], "evidence-team": ["processor"]}'
LOCAL_GROUP_ROLE_MAP={}

# ---------------------------------------------------------------------------
# LDAP configuration (used when ROLE_RESOLVER=ldap)
# ---------------------------------------------------------------------------
# JSON object mapping LDAP group DNs to lists of ECUBE role strings.
# Example: '{"CN=EvidenceAdmins,DC=corp,DC=example,DC=com": ["admin"]}'
LDAP_GROUP_ROLE_MAP={}

# LDAP server URI (e.g. ldap://ldap.example.com or ldaps://ldap.example.com:636)
LDAP_SERVER=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=

# ---------------------------------------------------------------------------
# OIDC configuration (used when ROLE_RESOLVER=oidc)
# ---------------------------------------------------------------------------
# Full OIDC discovery URL (.well-known/openid-configuration endpoint)
OIDC_DISCOVERY_URL=

# OIDC client credentials
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Expected audience for 'aud' claim validation (leave empty to skip)
OIDC_AUDIENCE=

# Name of the JWT claim containing group memberships
OIDC_GROUP_CLAIM_NAME=groups

# JSON object mapping OIDC group values to lists of ECUBE role strings.
# Example: '{"evidence-admins": ["admin"], "evidence-team": ["processor"]}'
OIDC_GROUP_ROLE_MAP={}

# Allowed JWT algorithms for OIDC token validation (JSON list)
OIDC_ALLOWED_ALGORITHMS=["RS256","RS384","RS512","ES256","ES384","ES512"]

# Timeout in seconds for OIDC discovery document fetch
OIDC_DISCOVERY_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# TLS certificates (native deployments)
# ---------------------------------------------------------------------------
# Used by the systemd unit / uvicorn for native installs.
# Docker deployments mount certs via ECUBE_CERTS_DIR (see below).
# For production, point to your signed certificate files.
TLS_CERTFILE=./deploy/certs/cert.pem
TLS_KEYFILE=./deploy/certs/key.pem

# ---------------------------------------------------------------------------
# Reverse proxy settings
# ---------------------------------------------------------------------------
# Trust X-Forwarded-For / X-Real-IP headers for client IP detection.
# Leave false unless the service sits behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# ---------------------------------------------------------------------------
# Frontend serving (native deployments)
# ---------------------------------------------------------------------------
# Absolute path to the Vue/Vite dist/ directory.  FastAPI serves these
# static files and provides SPA fallback when set.
# install.sh sets this automatically (e.g. /opt/ecube/www).
# Docker images set this via the Dockerfile ENV directive.
# Leave empty for development when running the Vite dev server separately.
# SERVE_FRONTEND_PATH=

# ---------------------------------------------------------------------------
# Docker Compose deployment overrides
# ---------------------------------------------------------------------------
# The variables below are only used by docker-compose.yml for container
# configuration.  They have sensible defaults and are ignored by native
# installs.  Uncomment to override.

# Host port mapped to the container's ECUBE_PORT.
# UI_PORT=8443

# Set to "true" to disable TLS (also set ECUBE_PORT=8000 and UI_PORT=8000).
# ECUBE_NO_TLS=false

# Container listening port (8443 with TLS, 8000 without).
# ECUBE_PORT=8443

# Host directory containing cert.pem and key.pem for Docker TLS.
# On first start the container generates a self-signed certificate if
# no cert files exist.  Set this variable and uncomment the certs volume
# in docker-compose.ecube.yml to mount your own certificate instead.
# ECUBE_CERTS_DIR=./deploy/certs

# Host directory containing custom UI themes.  The Docker image includes
# built-in themes; only set this if you want to override them.
# ECUBE_THEMES_DIR=./deploy/themes

# Host port mapped to the PostgreSQL container (for external tools).
# Not published by default.  To expose, add a ports mapping to the
# postgres service in docker-compose.ecube.yml.
# POSTGRES_HOST_PORT=5432

# ---------------------------------------------------------------------------
# Operational tuning
# ---------------------------------------------------------------------------
# Days to retain audit log records (0 = keep forever)
AUDIT_LOG_RETENTION_DAYS=365

# Seconds before a copy job is marked FAILED with timeout (0 = no timeout)
COPY_JOB_TIMEOUT=3600

# Seconds between automatic USB discovery sweeps (0 = disabled)
USB_DISCOVERY_INTERVAL=30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Root log level: DEBUG, INFO, WARNING, ERROR
# DEBUG gives verbose output useful for first-run troubleshooting.
LOG_LEVEL=DEBUG

# Log output format: "text" (human-readable) or "json" (structured)
LOG_FORMAT=text

# Optional path to a log file (leave empty for stdout only)
LOG_FILE=

# Maximum size in bytes of a single log file before rotation (default 10 MB)
LOG_FILE_MAX_BYTES=10485760

# Number of rotated backup log files to keep
LOG_FILE_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# Copy engine tuning
# ---------------------------------------------------------------------------
# Chunk size in bytes for file copy and checksum computation (default 1 MB)
COPY_CHUNK_SIZE_BYTES=1048576

# Default worker thread pool size
COPY_DEFAULT_THREAD_COUNT=4

# Default maximum per-file retries
COPY_DEFAULT_MAX_RETRIES=3

# Default retry delay in seconds
COPY_DEFAULT_RETRY_DELAY_SECONDS=1.0

# ---------------------------------------------------------------------------
# Subprocess & system paths
# ---------------------------------------------------------------------------
# Timeout in seconds for subprocess calls (mount, umount, sync)
SUBPROCESS_TIMEOUT_SECONDS=30

# Paths to system binaries
MOUNT_BINARY_PATH=/bin/mount
SYNC_BINARY_PATH=/bin/sync
UMOUNT_BINARY_PATH=/bin/umount

# Filesystem paths
PROCFS_MOUNTS_PATH=/proc/mounts
SYSFS_USB_DEVICES_PATH=/sys/bus/usb/devices
SYSFS_BLOCK_PATH=/sys/block

# ---------------------------------------------------------------------------
# Audit log pagination
# ---------------------------------------------------------------------------
# Default page size for audit log queries
AUDIT_LOG_DEFAULT_LIMIT=100

# Maximum allowed page size for audit log queries
AUDIT_LOG_MAX_LIMIT=1000

# ---------------------------------------------------------------------------
# Database connection pool
# ---------------------------------------------------------------------------
# Number of persistent connections in the pool
DB_POOL_SIZE=5

# Maximum overflow connections above pool size
DB_POOL_MAX_OVERFLOW=10

# Seconds after which a connection is recycled (-1 = disabled)
DB_POOL_RECYCLE_SECONDS=-1

# ---------------------------------------------------------------------------
# OpenAPI metadata
# ---------------------------------------------------------------------------
API_CONTACT_NAME=ECUBE Support
API_CONTACT_EMAIL=support@ecube.local

# ---------------------------------------------------------------------------
# Session & cookie
# ---------------------------------------------------------------------------
# Session storage backend: "cookie" (signed browser cookies) or "redis" (server-side)
SESSION_BACKEND=cookie

# Session cookie name
SESSION_COOKIE_NAME=ecube_session

# Cookie lifetime in seconds (default 1 hour; use 86400 for 24 hours)
SESSION_COOKIE_EXPIRATION_SECONDS=3600

# Domain scope for the cookie (leave empty for browser default)
SESSION_COOKIE_DOMAIN=

# Send cookie only over HTTPS (set false for local dev without TLS)
# Note: must be true when SESSION_COOKIE_SAMESITE=none (browsers reject
# SameSite=None cookies without the Secure flag).
SESSION_COOKIE_SECURE=true

# Note: HttpOnly is always enabled on session cookies and cannot be disabled.

# SameSite attribute: "strict", "lax", or "none"
SESSION_COOKIE_SAMESITE=lax

# ---------------------------------------------------------------------------
# Redis (required only when SESSION_BACKEND=redis)
# ---------------------------------------------------------------------------
# Redis connection URL (e.g. redis://localhost:6379/0)
REDIS_URL=

# Timeout in seconds for establishing a Redis connection
REDIS_CONNECTION_TIMEOUT=5

# Enable TCP keepalive on the Redis socket
REDIS_SOCKET_KEEPALIVE=true
