{
	"info": {
		"_postman_id": "ecube-api-collection",
		"name": "ECUBE API",
		"description": "Evidence Copying & USB Based Export — Full API Collection.\n\nSet the `base_url` variable (default: http://localhost:8000) and authenticate via the Auth > Login request to populate the `token` variable automatically.\n\n**Prerequisites:** The ECUBE OS groups (`ecube-admins`, `ecube-managers`, `ecube-processors`, `ecube-auditors`) must exist on the host before running the Admin — OS Users / OS Groups folders. Run `/setup/initialize` first, or create them manually (`sudo groupadd ecube-admins` etc.). If groups are missing, those requests will return 422 (Unprocessable Entity).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "test",
			"script": {
				"exec": [
					"(function () {",
					"    pm.test('No server errors (status < 500)', function () {",
					"        pm.expect(pm.response.code).to.be.below(500);",
					"    });",
					"})();"
				],
				"type": "text/javascript"
			}
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "admin_username",
			"value": "ecube-admin",
			"type": "string"
		},
		{
			"key": "admin_password",
			"value": "s3cret",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health & Version",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Health returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Returns 200 OK for readiness/liveness probes."
					}
				},
				{
					"name": "Version Info",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Version returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/introspection/version",
							"host": ["{{base_url}}"],
							"path": ["introspection", "version"]
						},
						"description": "Returns application and API version. No auth required."
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// When a token is already injected (CI via --env-var), skip login assertions.",
									"// pm.variables.get checks all scopes: environment, collection, and global.",
									"if (pm.variables.get('token')) {",
									"    pm.test('Login skipped — token already injected', function () {",
									"        pm.expect(true).to.be.true;",
									"    });",
									"} else {",
									"    pm.test('Login returns 200', function () {",
									"        pm.response.to.have.status(200);",
									"    });",
									"",
									"    pm.test('Response contains access_token', function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('access_token');",
									"        pm.collectionVariables.set('token', jsonData.access_token);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/token",
							"host": ["{{base_url}}"],
							"path": ["auth", "token"]
						},
						"description": "Authenticate with OS credentials. Returns a signed JWT Bearer token.\nThe token is automatically saved to the collection `token` variable."
					}
				}
			]
		},
		{
			"name": "Setup",
			"item": [
				{
					"name": "Get Setup Status",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/setup/status",
							"host": ["{{base_url}}"],
							"path": ["setup", "status"]
						},
						"description": "Check if system has been initialized with an admin user."
					}
				},
				{
					"name": "Initialize System",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/setup/initialize",
							"host": ["{{base_url}}"],
							"path": ["setup", "initialize"]
						},
						"description": "Create OS groups, admin user, and seed DB with admin role. Returns 409 if already initialized."
					}
				}
			]
		},
		{
			"name": "Database Setup",
			"item": [
				{
					"name": "Test DB Connection",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"host\": \"localhost\",\n  \"port\": 5432,\n  \"admin_username\": \"postgres\",\n  \"admin_password\": \"postgres\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/setup/database/test-connection",
							"host": ["{{base_url}}"],
							"path": ["setup", "database", "test-connection"]
						},
						"description": "Test PostgreSQL connectivity. Unauthenticated during initial setup; admin-required after initialization."
					}
				},
				{
					"name": "Provision Database",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"host\": \"localhost\",\n  \"port\": 5432,\n  \"admin_username\": \"postgres\",\n  \"admin_password\": \"postgres\",\n  \"app_database\": \"ecube\",\n  \"app_username\": \"ecube_app\",\n  \"app_password\": \"ecube_app_password\",\n  \"force\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/setup/database/provision",
							"host": ["{{base_url}}"],
							"path": ["setup", "database", "provision"]
						},
						"description": "Create app user/database and run Alembic migrations. Returns 409 if already provisioned."
					}
				},
				{
					"name": "Get DB Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/setup/database/status",
							"host": ["{{base_url}}"],
							"path": ["setup", "database", "status"]
						},
						"description": "Verify current database state and connectivity. Requires admin role."
					}
				},
				{
					"name": "Update DB Settings",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"host\": \"localhost\",\n  \"port\": 5432\n}"
						},
						"url": {
							"raw": "{{base_url}}/setup/database/settings",
							"host": ["{{base_url}}"],
							"path": ["setup", "database", "settings"]
						},
						"description": "Update database configuration. Requires admin role."
					}
				}
			]
		},
		{
			"name": "Drives",
			"item": [
				{
					"name": "List Drives",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('List Drives returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/drives",
							"host": ["{{base_url}}"],
							"path": ["drives"],
							"query": [
								{ "key": "project_id", "value": "", "disabled": true, "description": "Filter drives by project ID" }
							]
						},
						"description": "List all USB drives with state and project bindings. Optional project_id filter. Roles: admin, manager, processor, auditor."
					}
				},
				{
					"name": "Refresh Drives",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/drives/refresh",
							"host": ["{{base_url}}"],
							"path": ["drives", "refresh"]
						},
						"description": "Trigger USB discovery sync, update topology, and recompute drive states. Roles: admin, manager."
					}
				},
				{
					"name": "Initialize Drive",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"project_id\": \"PROJECT-001\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/drives/:drive_id/initialize",
							"host": ["{{base_url}}"],
							"path": ["drives", ":drive_id", "initialize"],
							"variable": [
								{
									"key": "drive_id",
									"value": "1",
									"description": "ID of the drive to initialize"
								}
							]
						},
						"description": "Bind drive to a project and transition from AVAILABLE to IN_USE. Roles: admin, manager."
					}
				},
				{
					"name": "Format Drive",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filesystem_type\": \"exfat\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/drives/:drive_id/format",
							"host": ["{{base_url}}"],
							"path": ["drives", ":drive_id", "format"],
							"variable": [
								{
									"key": "drive_id",
									"value": "1",
									"description": "ID of the drive to format"
								}
							]
						},
						"description": "Format drive with specified filesystem (ext4 or exfat). Drive must be AVAILABLE and unmounted. Roles: admin, manager."
					}
				},
				{
					"name": "Prepare Eject",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/drives/:drive_id/prepare-eject",
							"host": ["{{base_url}}"],
							"path": ["drives", ":drive_id", "prepare-eject"],
							"variable": [
								{
									"key": "drive_id",
									"value": "1",
									"description": "ID of the drive to prepare for ejection"
								}
							]
						},
						"description": "Complete copy/verify and transition drive back to AVAILABLE for safe removal. Roles: admin, manager."
					}
				}
			]
		},
		{
			"name": "Mounts",
			"item": [
				{
					"name": "List Mounts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('List Mounts returns 200', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/mounts",
							"host": ["{{base_url}}"],
							"path": ["mounts"]
						},
						"description": "List all registered network mounts and connectivity status. Roles: admin, manager, processor, auditor."
					}
				},
				{
					"name": "Add Mount",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"SMB\",\n  \"remote_path\": \"//server/share\",\n  \"local_mount_point\": \"/mnt/evidence\",\n  \"username\": \"user\",\n  \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mounts",
							"host": ["{{base_url}}"],
							"path": ["mounts"]
						},
						"description": "Register a new network mount (SMB/NFS). Required fields: type (SMB or NFS), remote_path, local_mount_point. Optional: username, password, credentials_file. Roles: admin, manager."
					}
				},
				{
					"name": "Remove Mount",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/mounts/:mount_id",
							"host": ["{{base_url}}"],
							"path": ["mounts", ":mount_id"],
							"variable": [
								{
									"key": "mount_id",
									"value": "1",
									"description": "ID of the mount to remove"
								}
							]
						},
						"description": "Delete mount configuration and credentials. Returns 204. Roles: admin, manager."
					}
				},
				{
					"name": "Validate All Mounts",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/mounts/validate",
							"host": ["{{base_url}}"],
							"path": ["mounts", "validate"]
						},
						"description": "Test connectivity for all mounts and update status. Roles: admin, manager."
					}
				},
				{
					"name": "Validate Single Mount",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/mounts/:mount_id/validate",
							"host": ["{{base_url}}"],
							"path": ["mounts", ":mount_id", "validate"],
							"variable": [
								{
									"key": "mount_id",
									"value": "1",
									"description": "ID of the mount to validate"
								}
							]
						},
						"description": "Test connectivity for a specific mount. Roles: admin, manager."
					}
				}
			]
		},
		{
			"name": "Jobs",
			"item": [
				{
					"name": "Create Job (Explicit Drive)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"project_id\": \"PROJECT-001\",\n  \"evidence_number\": \"EV-001\",\n  \"source_path\": \"/mnt/source/evidence\",\n  \"drive_id\": 1,\n  \"thread_count\": 4,\n  \"max_file_retries\": 3,\n  \"retry_delay_seconds\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/jobs",
							"host": ["{{base_url}}"],
							"path": ["jobs"]
						},
						"description": "Create an export job with an explicit drive_id. The drive must be AVAILABLE and its current_project_id must match or be null. If the drive is currently unbound, it is automatically bound to the requested project. Starts in PENDING state. Roles: admin, manager, processor."
					}
				},
				{
					"name": "Create Job (Auto-Assign Drive)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"project_id\": \"PROJECT-001\",\n  \"evidence_number\": \"EV-001\",\n  \"source_path\": \"/mnt/source/evidence\",\n  \"thread_count\": 4\n}"
						},
						"url": {
							"raw": "{{base_url}}/jobs",
							"host": ["{{base_url}}"],
							"path": ["jobs"]
						},
						"description": "Create an export job without drive_id to auto-assign a drive. If exactly one AVAILABLE drive is bound to the project, it is selected (409 if the drive is temporarily unavailable — retry). If none are bound, an unbound AVAILABLE drive is used and the project is assigned to it. Returns 409 if multiple project-bound drives exist (specify drive_id) or if no usable drive can be acquired for the requested project. Roles: admin, manager, processor."
					}
				},
				{
					"name": "Get Job",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/jobs/:job_id",
							"host": ["{{base_url}}"],
							"path": ["jobs", ":job_id"],
							"variable": [
								{
									"key": "job_id",
									"value": "1",
									"description": "ID of the export job"
								}
							]
						},
						"description": "Retrieve job state, progress, timestamps, file counts, drive info, and error summary. Roles: admin, manager, processor, auditor."
					}
				},
				{
					"name": "Start Job",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"thread_count\": 4\n}"
						},
						"url": {
							"raw": "{{base_url}}/jobs/:job_id/start",
							"host": ["{{base_url}}"],
							"path": ["jobs", ":job_id", "start"],
							"variable": [
								{
									"key": "job_id",
									"value": "1",
									"description": "ID of the job to start"
								}
							]
						},
						"description": "Launch copy process in background. State transitions to RUNNING. Sets started_by to the authenticated user and records started_at timestamp. Roles: admin, manager, processor."
					}
				},
				{
					"name": "Verify Job",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/jobs/:job_id/verify",
							"host": ["{{base_url}}"],
							"path": ["jobs", ":job_id", "verify"],
							"variable": [
								{
									"key": "job_id",
									"value": "1",
									"description": "ID of the job to verify"
								}
							]
						},
						"description": "Verify copied data integrity (hash comparison). State: VERIFYING → COMPLETED or FAILED. Response includes files_succeeded, files_failed, and error_summary. Roles: admin, manager, processor."
					}
				},
				{
					"name": "Create Manifest",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/jobs/:job_id/manifest",
							"host": ["{{base_url}}"],
							"path": ["jobs", ":job_id", "manifest"],
							"variable": [
								{
									"key": "job_id",
									"value": "1",
									"description": "ID of the job to generate manifest for"
								}
							]
						},
						"description": "Generate JSON manifest on USB drive with file hashes and copy metadata. Response includes full job state with enriched fields. Roles: admin, manager, processor."
					}
				}
			]
		},
		{
			"name": "Files",
			"item": [
				{
					"name": "Get File Hashes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/files/:file_id/hashes",
							"host": ["{{base_url}}"],
							"path": ["files", ":file_id", "hashes"],
							"variable": [
								{
									"key": "file_id",
									"value": "1",
									"description": "ID of the export file"
								}
							]
						},
						"description": "Return MD5 and SHA-256 hashes for a single export file. Roles: admin, auditor."
					}
				},
				{
					"name": "Compare Files",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"file_id_a\": 1,\n  \"file_id_b\": 2\n}"
						},
						"url": {
							"raw": "{{base_url}}/files/compare",
							"host": ["{{base_url}}"],
							"path": ["files", "compare"]
						},
						"description": "Compare two files by hash, size, and relative path. Roles: admin, auditor."
					}
				}
			]
		},
		{
			"name": "Introspection",
			"item": [
				{
					"name": "List Drives (Introspection)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/introspection/drives",
							"host": ["{{base_url}}"],
							"path": ["introspection", "drives"]
						},
						"description": "Inventory of USB drives: IDs, capacity, state, project bindings. Roles: all authenticated."
					}
				},
				{
					"name": "USB Topology",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/introspection/usb/topology",
							"host": ["{{base_url}}"],
							"path": ["introspection", "usb", "topology"]
						},
						"description": "Introspect USB hubs/ports from sysfs. Roles: all authenticated."
					}
				},
				{
					"name": "Block Devices",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/introspection/block-devices",
